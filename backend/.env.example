# Required: Hugging Face token for model invocation
HF_TOKEN=hf_your_token_here

# Optional fallback variable name
# HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Optional: Router embedding model (used for semantic capability matching)
HF_ROUTER_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: Backend API URL used by seed.py
MARKETPLACE_API_URL=http://localhost:8000/api
